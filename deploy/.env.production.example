COMPOSE_PROJECT_NAME=blog-platform
HTTP_PORT=80
HTTPS_PORT=443

# Use http://SERVER_PUBLIC_IP for first smoke test, then https://your-domain.com after DNS/SSL.
PUBLIC_DOMAIN=your-domain.com
PUBLIC_FRONTEND_ORIGIN=https://your-domain.com
PUBLIC_API_BASE_URL=https://your-domain.com

MYSQL_DATABASE=blog_app_apis
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
DB_USERNAME=blog_user
DB_PASSWORD=replace-with-strong-application-password

JWT_SECRET=replace-with-a-long-random-secret-at-least-64-characters-long
JWT_EXPIRATION_MS=18000000
